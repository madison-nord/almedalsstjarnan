{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint when a TypeScript source file is saved. Reports errors and auto-fixes fixable issues.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run `pnpm run lint` and report any errors. If there are fixable errors, run `pnpm run lint:fix` and report what was fixed."
  }
}